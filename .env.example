# Backend / frontend wiring
EMAIL_ASSISTANT_API=http://127.0.0.1:8000
GMAIL_ACCOUNT=your_email@gmail.com

# Optional defaults for compose form
EMAIL_DEFAULT_TO=friend@example.com

# Risk agent defaults
RISK_THRESHOLD=0.65
RISK_LLM_MODEL=gpt-4.1-mini
RISK_LLM_ENABLED=true
# rules_only | hybrid | llm_only
RISK_DECISION_MODE=hybrid
# If true and llm_only mode cannot call the LLM, quarantine by default.
RISK_FAIL_CLOSED=false
RISK_QUARANTINE_PATH=data/quarantine.jsonl
RISK_FEEDBACK_PATH=data/training_feedback.jsonl
RISK_MODEL_VERSION=risk-agent-v1
